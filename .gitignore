# Install state marker
.occb-last-update

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code project harness (not part of the scaffold)
# — except learnings, which are team-useful and should ship with the repo.
# Use /.claude/* (not /.claude/) so the directory itself isn't excluded;
# git can't un-ignore contents of an ignored parent directory.
/.claude/*
!/.claude/learnings/

# Misc
*.log
