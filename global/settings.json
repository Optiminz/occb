{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh"
  },
  "theme": "dark",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.development)",
      "Read(./.env.test)",
      "Read(./.env.testing)",
      "Read(./.env.production)",
      "Read(./.env.staging)",
      "Read(**/*sensitive_data*/**)"
    ]
  }
}
